<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Spring Boot default configs -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!-- ============================= -->
    <!-- LOKI APPENDER -->
    <!-- ============================= -->
    <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">

        <http>
            <url>http://localhost:3100/loki/api/v1/push</url>
        </http>

        <format>
            <!--  FIXED: No invalid escaping -->
            <label>
                <pattern>app=${spring.application.name},host=localhost,level=%level</pattern>
            </label>

            <message>
                <pattern>
                    %d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg traceId=%X{traceId:-} spanId=%X{spanId:-}
                </pattern>
            </message>

            <sortByTime>true</sortByTime>
        </format>
    </appender>

    <!-- ============================= -->
    <!-- ASYNC WRAPPER (PERFORMANCE) -->
    <!-- ============================= -->
    <appender name="ASYNC_LOKI" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="LOKI"/>
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
    </appender>

    <!-- ============================= -->
    <!-- ROOT LOGGER -->
    <!-- ============================= -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_LOKI"/>
    </root>

    <!-- ============================= -->
    <!-- REDUCE NOISE -->
    <!-- ============================= -->
    <logger name="org.springframework.security" level="WARN"/>
    <logger name="org.springframework.web" level="WARN"/>
    <logger name="org.springframework.cloud" level="WARN"/>

</configuration>